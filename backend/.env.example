# Backend configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Detection engine: "ultralytics" | "yolov3_opencv"
DETECTOR_ENGINE=ultralytics

# Path to model weights (relative to backend/ or absolute)
# yolov8s.pt = better accuracy than yolov8n.pt (recommended)
MODEL_PATH=models/yolov8s.pt

# Inference image size (640–1280; higher = better detection, slower)
INFERENCE_IMGSZ=960

# Confidence threshold (0.0 – 1.0) — lower detects more objects
CONFIDENCE_THRESHOLD=0.25

# IoU threshold for non-max suppression
IOU_THRESHOLD=0.45

# YOLOv3 OpenCV DNN paths (when DETECTOR_ENGINE=yolov3_opencv)
YOLOV3_WEIGHTS=models/yolov3.weights
YOLOV3_CONFIG=models/yolov3.cfg
YOLOV3_NAMES=models/coco.names
